---js
const eleventyNavigation = {
	key: "Home",
	order: 1
};
---
{% set latestPost = collections.posts | last %}
<section class="home-intro">
	<h1>Engineered Thoughts</h1>
</section>

{% if latestPost %}
<section class="home-writing" aria-labelledby="writing-heading">
	<h2 id="writing-heading">Writing</h2>
	<a class="home-post" href="{{ latestPost.url }}">
		<span class="home-post-title">{{ latestPost.data.title }}</span>
		<time class="home-post-date" datetime="{{ latestPost.date | htmlDateString }}">{{ latestPost.date | readableDate("LLLL yyyy") }}</time>
	</a>
</section>
{% endif %}
